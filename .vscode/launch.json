{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug w/o halt",
            "cwd": "${workspaceFolder}",
            "executable": "./build/Debug/stm32f407_ethernet.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "interface": "swd",
            "device": "STM32F407VG",
            "runToEntryPoint": null,
            "showDevDebugOutput": "raw",
            "svdFile": "${workspaceRoot}/.vscode/STM32F407.svd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 1
            },
            "openOCDLaunchCommands": ["transport select hla_swd"],
            // "preLaunchTask": "${defaultBuildTask}",
            // "preLaunchTask": "flash-firmware",
            "preLaunchTask": "CMake_flash",
            // "postAttachCommands": ["continue"]
        },
        {
            "name": "Debug",
            "cwd": "${workspaceFolder}",
            "executable": "./build/Debug/stm32f407_ethernet.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "interface": "swd",
            "device": "STM32F407VG",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "svdFile": "${workspaceRoot}/.vscode/STM32F407.svd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 1
            },
            "openOCDLaunchCommands": ["transport select hla_swd"],
            // "preLaunchTask": "${defaultBuildTask}",
            // "preLaunchTask": "flash-firmware",
            "preLaunchTask": "CMake_flash"
        }
    ]
}
